{
  "name": "plov-scalping-terminal",
  "version": 2,
  "builds": [{ "src": "index.html", "use": "@vercel/static" }],
  "routes": [{ "src": "/(.*)", "dest": "/index.html" }],
  "headers": [{
    "source": "/(.*)",
    "headers": [
      { "key": "X-Frame-Options", "value": "DENY" },
      { "key": "X-Content-Type-Options", "value": "nosniff" },
      { "key": "Content-Security-Policy", "value": "default-src 'self' https: wss: 'unsafe-inline' 'unsafe-eval'" }
    ]
  }]
}
