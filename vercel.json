{
  "version": 2,
  "builds": [
    { "src": "**/*", "use": "@vercel/static" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Content-Security-Policy",
          "value": "default-src 'self' https: wss: 'unsafe-inline' 'unsafe-eval'" }
      ]
    }
  ]
}
